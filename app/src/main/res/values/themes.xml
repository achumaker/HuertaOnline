<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ════ TEMA CLARO ════════════════════════════════════════ -->
    <style name="Theme.HuertaOnline"
        parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Colores Material -->
        <item name="colorPrimary">@color/verde_500</item>
        <item name="colorPrimaryVariant">@color/verde_700</item>
        <item name="colorOnPrimary">@color/blanco</item>
        <item name="colorSecondary">@color/naranja_500</item>
        <item name="colorOnSecondary">@color/blanco</item>
        <item name="colorSurface">@color/blanco</item>
        <item name="colorOnSurface">@color/gris_950</item>
        <item name="android:colorBackground">@color/gris_100</item>
        <item name="colorError">@color/rojo_oscuro</item>

        <!-- Barra de estado verde -->
        <item name="android:statusBarColor">@color/verde_500</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>

        <!-- Inputs y chips con color primario -->
        <item name="colorControlActivated">@color/verde_500</item>
        <item name="colorControlHighlight">@color/verde_50</item>
    </style>

    <!-- Tema para Login y Registro -->
    <style name="Theme.HuertaOnline.Auth"
        parent="Theme.HuertaOnline">
        <item name="android:windowBackground">@color/verde_50</item>
    </style>

</resources>