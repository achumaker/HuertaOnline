<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="8dp">
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="12dp">
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/tvFecha"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp" android:textColor="@color/texto_muted"/>
            <TextView android:id="@+id/tvEstado"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textStyle="bold"/>
        </LinearLayout>
        <TextView android:id="@+id/tvItems"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="13sp" android:layout_marginTop="4dp"
            android:maxLines="2" android:ellipsize="end"
            android:textColor="@color/texto_oscuro"/>
        <TextView android:id="@+id/tvDireccion"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="12sp" android:layout_marginTop="4dp"
            android:visibility="gone"
            android:textColor="@color/texto_muted"/>
        <TextView android:id="@+id/tvTotal"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="15sp" android:textStyle="bold"
            android:textColor="@color/verde"
            android:gravity="end" android:layout_marginTop="4dp"/>
        <Button android:id="@+id/btnAccion"
            android:layout_width="wrap_content" android:layout_height="32dp"
            android:layout_gravity="end" android:layout_marginTop="4dp"
            android:text="MARCAR COMO ENVIADO" android:textSize="10sp"
            android:backgroundTint="@color/naranja"
            android:visibility="gone"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>