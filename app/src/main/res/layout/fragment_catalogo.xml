<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingTop="70dp"
    android:background="@color/fondo">

    <!-- Buscador -->
    <androidx.appcompat.widget.SearchView
        android:id="@+id/searchView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/blanco"
        app:iconifiedByDefault="false"
        app:queryHint="Buscar producto o productor..."
        android:padding="4dp"/>

    <!-- Chips de categoría -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="@color/blanco">
        <com.google.android.material.chip.ChipGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            app:singleSelection="true">
            <com.google.android.material.chip.Chip android:id="@+id/chipTodas"     android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Todas"     style="@style/Widget.MaterialComponents.Chip.Filter"/>
            <com.google.android.material.chip.Chip android:id="@+id/chipVerduras"  android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Verduras"  style="@style/Widget.MaterialComponents.Chip.Filter"/>
            <com.google.android.material.chip.Chip android:id="@+id/chipFrutas"    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Frutas"    style="@style/Widget.MaterialComponents.Chip.Filter"/>
            <com.google.android.material.chip.Chip android:id="@+id/chipConservas" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Conservas" style="@style/Widget.MaterialComponents.Chip.Filter"/>
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- RecyclerView en grid 2 columnas -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerProductos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <TextView
        android:id="@+id/tvVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No hay productos disponibles"
        android:textColor="@color/texto_muted"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

</LinearLayout>