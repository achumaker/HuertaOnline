<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permiso de internet (obligatorio para Firebase) -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Permiso para seleccionar imágenes de la galería -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>

    <application
        android:name=".HuertaOnlineApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HuertaOnline">

        <!-- Pantalla de LOGIN: es el punto de entrada de la app -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.HuertaOnline.Auth">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Pantalla de REGISTRO -->
        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.HuertaOnline.Auth"/>

        <!-- MAIN: contiene el NavHost con todos los Fragments -->
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false"/>

    </application>

</manifest>